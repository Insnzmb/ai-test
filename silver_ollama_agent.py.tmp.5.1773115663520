        self.model = model
        self.url = url.rstrip("/") + "/api/generate"
        self.timeout = timeout
        self.last_call = 0.0
        self.cooldown_until = 0.0
        self.knowledge_text = (knowledge_text or "").strip()
        self.walkthrough_text = (walkthrough_text or "").strip()
        self.controls_text = (controls_text or "").strip()

