def clamp(value, lo, hi):
    return max(lo, min(hi, value))


def is_boot_map(state):
    return (
        state["battle_mode"] == 0
        and state["map_group"] == 0
        and state["map_number"] == 0
        and state["map_status"] in (0, 255)
    )


def host_sync_available(state):
    if state["host_map_group"] < 0 or state["host_map_number"] < 0:
        return False
    if state["host_x"] < 0 or state["host_y"] < 0:
        return False
    # Ignore default zero telemetry while Silver is still in boot shell.
    if (
        is_boot_map(state)
        and state["host_map_group"] == 0
        and state["host_map_number"] == 0
        and state["host_x"] == 0
        and state["host_y"] == 0
        and state["party_count"] == 0
    ):
        return False
    return True


def pulse(frame, interval, width=1, offset=0):
    if interval <= 0:
        return False
    # Telemetry commonly advances in 2-frame steps; normalize to avoid
    # parity-locked pulses that can stall menu automation.
    tick = frame // 2
    pos = (tick + offset) % interval
    return pos < width


def _pick_axis_direction(positive_pressed, negative_pressed, positive_name, negative_name, fallback):
    if positive_pressed and not negative_pressed:
        return positive_name
    if negative_pressed and not positive_pressed:
        return negative_name
    if positive_pressed and negative_pressed and fallback in {positive_name, negative_name}:
        return fallback
    return None


def _movement_action_from_mask(mask: int, fallback: str = "NONE"):
    horiz = _pick_axis_direction(
        bool(mask & KEY_RIGHT_MASK),
        bool(mask & KEY_LEFT_MASK),
        "RIGHT",
        "LEFT",
        fallback,
    )
    vert = _pick_axis_direction(
        bool(mask & KEY_DOWN_MASK),
        bool(mask & KEY_UP_MASK),
        "DOWN",
        "UP",
        fallback,
    )
    if horiz and vert:
        if fallback in HORIZONTAL_ACTIONS:
            return horiz
        if fallback in VERTICAL_ACTIONS:
            return vert
        return vert
    return vert or horiz


def action_from_mask(mask: int, allowed=None, fallback: str = "NONE"):
    allowed_set = set(allowed or ACTIONS.keys())
    mask = int(mask or 0) & 0xFF
    if mask == 0:
        return "NONE" if "NONE" in allowed_set else None

    movement = _movement_action_from_mask(mask, fallback=fallback)
    candidates = []
    if movement and (mask & KEY_A_MASK):
        movement_a = f"{movement}_A"
        if movement_a in allowed_set:
            candidates.append(movement_a)
    if mask & KEY_A_MASK and "A" in allowed_set:
        candidates.append("A")
    if mask & KEY_B_MASK and "B" in allowed_set:
        candidates.append("B")
    if mask & KEY_START_MASK and "START" in allowed_set:
        candidates.append("START")
    if mask & KEY_SELECT_MASK and "SELECT" in allowed_set:
        candidates.append("SELECT")
    if movement and movement in allowed_set:
        candidates.append(movement)
    if not candidates and "NONE" in allowed_set:
        candidates.append("NONE")
    return candidates[0] if candidates else None


def detect_manual_override_action(state, allowed, fallback: str = "NONE"):
    raw_mask = int(state.get("raw_keys", 0) or 0) & 0xFF
    if raw_mask == 0:
        return None

    ai_mask = 0
    if int(state.get("bridge_ai_ttl", 0) or 0) > 0:
        ai_mask = int(state.get("bridge_ai_keys", 0) or 0) & 0xFF

    manual_mask = raw_mask & (~ai_mask & 0xFF)
    if manual_mask == 0 and ai_mask == 0:
        manual_mask = raw_mask
    if manual_mask == 0:
        return None
    return action_from_mask(manual_mask, allowed=allowed, fallback=fallback)


NAME_ENTRY_GRID = (
    "ABCDEFGHI",
    "JKLMNOPQR",
    "STUVWXYZ ",
    "-?!/.,   ",
)


def derive_agent_name(model_name: str):
    raw = re.sub(r"[^A-Za-z0-9]", "", (model_name or "")).upper()
    if "LLAMA" in raw:
        return "OLLAMA"
    if not raw:
        return "AI"
    return raw[:7]


def build_name_entry_queue(name: str):
    positions = {}
    for row, text in enumerate(NAME_ENTRY_GRID):
        for col, ch in enumerate(text):
            if ch != " " and ch not in positions:
                positions[ch] = (row, col)

    row = 0
    col = 0
    queue = []
    # Drive to top-left so typing is deterministic regardless of cursor start.
    # Use exact grid bounds (4 rows × 9 cols) rather than an arbitrary constant
    # so we never overshoot and risk wrapping or bouncing off grid edges.
    _grid_rows = len(NAME_ENTRY_GRID)          # 4
    _grid_cols = len(NAME_ENTRY_GRID[0])       # 9
    queue.extend(["UP"] * (_grid_rows - 1))    # max 3 moves to reach row 0
    queue.extend(["LEFT"] * (_grid_cols - 1))  # max 8 moves to reach col 0
    for ch in (name or ""):
        if ch not in positions:
            continue
        target_row, target_col = positions[ch]
        while row < target_row:
            queue.append("DOWN")
            row += 1
        while row > target_row:
            queue.append("UP")
            row -= 1
        while col < target_col:
            queue.append("RIGHT")
            col += 1
        while col > target_col:
            queue.append("LEFT")
            col -= 1
        queue.append("A")

    queue.extend(["START", "A"])
    return queue


def default_map_constants_path():
    here = Path(__file__).resolve()
    candidates = []
    for parent in here.parents:
        candidates.append(parent / "pokegold-src" / "constants" / "map_constants.asm")
        candidates.append(parent / "constants" / "map_constants.asm")
    for path in candidates:
        if path.exists():
            return str(path)
    return ""


def load_map_index(path: Path):
    out = {}
    if not path or not path.exists():
        return out
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return out
    group = 0
    for line in lines:
        s = line.strip()
        if s.startswith("newgroup "):
            group += 1
            continue
        m = re.match(r"map_const\s+([A-Z0-9_]+).*;\s*(\d+)$", s)
        if not m:
            continue
        name = m.group(1)
        number = int(m.group(2))
        out[(group, number)] = name
    return out


