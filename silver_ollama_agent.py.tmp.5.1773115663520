    prev_action = None
    prev_guide_action = None
    prev_stall_pressure = 0
    prev_manual_override = False
    prev_reward_value = 0.0
    rx = ""
    step_since_save = 0
    last_hot_reload = time.time()
    stuck_count = 0
    desync_frames = 0
    intro_stall_frames = 0
    last_action = "NONE"
    action_history = deque(maxlen=10)
    boot_hammer_frames = 0
    repeated_action = None
    repeated_action_streak = 0
    last_manual_demo_action = None
    manual_demo_hold = 0

    while True:
        try:
            chunk = sock.recv(4096)
            if not chunk:
                raise OSError("socket closed")
            rx += chunk.decode("utf-8", errors="replace")
        except (socket.timeout, TimeoutError):
            continue
        except OSError:
            try:
                sock.close()
            except OSError:
                pass
            print("[silver-agent] reconnecting bridge...", flush=True)
            sock = connect_loop(args.host, args.port)
            print("[silver-agent] reconnected", flush=True)
            append_trace(trace_path, f"reconnect t={int(time.time())}")
            rx = ""
            prev_state = None
            prev_key = None
            prev_action = None
            prev_guide_action = None
            prev_stall_pressure = 0
            prev_manual_override = False
            stuck_count = 0
            desync_frames = 0
            intro_stall_frames = 0
            last_action = "NONE"
            action_history.clear()
            boot_hammer_frames = 0
            repeated_action = None
            repeated_action_streak = 0
            last_manual_demo_action = None
            manual_demo_hold = 0
            continue

        while True:
            at = rx.find("\n")
            if at < 0:
                break
            line = rx[:at]
            rx = rx[at + 1 :]
            state = parse_state(line)
            if not state:
                continue

            map_name = map_name_for_state(state, map_index)
            signal_snapshot = signal_map.summarize(state, map_name)
            objective = story_objective(state, map_name)
            progress_snapshot = progress_tracker.build_snapshot(state, map_name)
            intro_action = intro.decide(state)
            phase = intro.phase(state)
            key = state_key(state)
            allowed = allowed_actions(state, intro_action)
            if same_map(state):
                desync_frames = 0
            else:
                desync_frames = min(60000, desync_frames + 1)

            if prev_state is not None:
                unchanged = (
                    prev_state["map_group"] == state["map_group"]
                    and prev_state["map_number"] == state["map_number"]
                    and prev_state["x"] == state["x"]
                    and prev_state["y"] == state["y"]
                    and prev_state["in_menu"] == state["in_menu"]
                    and prev_state["script_running"] == state["script_running"]
                    and prev_state["map_status"] == state["map_status"]
                    and prev_state["menu_items"] == state["menu_items"]
                )
                if unchanged:
                    intro_stall_frames = min(12000, intro_stall_frames + 1)
                else:
                    intro_stall_frames = 0

            force_boot_action = None
            if (
                boot_hammer_frames > 0
                and state["battle_mode"] == 0
                and state["map_group"] == 0
                and state["map_number"] == 0
                and state["map_status"] in (0, 255)
            ):
                boot_state = (
                    state["map_status"] in (0, 255)
                    or state["script_running"] != 0
                    or is_continue_menu_candidate(state)
                )
                if boot_state:
                    if pulse(state["frame"], 4, 2, 1):
                        force_boot_action = "A"
                    else:
                        force_boot_action = "NONE"
                    boot_hammer_frames -= 1
                else:
                    boot_hammer_frames = 0

            if prev_state is not None and prev_action is not None and prev_key is not None:
                if prev_action in MOVEMENT_ACTIONS and prev_state["x"] == state["x"] and prev_state["y"] == state["y"]:
                    stuck_count += 1
                else:
                    stuck_count = 0

                teacher = teacher_action(prev_state, state)
                if teacher:
                    memory.observe_teacher(prev_key, teacher)

                reward = reward_for_transition(prev_state, state, prev_action)
                if prev_action == repeated_action:
                    repeated_action_streak += 1
                else:
                    repeated_action = prev_action
                    repeated_action_streak = 1
                reward_signal = evaluate_reward_signal(
                    prev_state,
                    state,
                    prev_action,
                    prev_guide_action,
                    prev_stall_pressure,
                    repeated_action_streak,
                    manual_override=prev_manual_override,
                )
                reward += reward_signal.reward_bonus
                memory.record_reward_signal(
                    reward_signal,
                    state_key=prev_key,
                    action=prev_action,
                    guide_action=prev_guide_action or "NONE",
                )
                smart_policy.observe_transition(
                    prev_state,
                    prev_action,
                    state,
                    reward,
                    reward_signal=reward_signal,
                    guide_action=prev_guide_action or "NONE",
                )
                meta_policy.observe_transition(
                    prev_state,
                    prev_action,
                    state,
                    reward,
                    reward_signal=reward_signal,
                    objective=objective,
                )
                recovery.observe_transition(
                    prev_state,
                    prev_action,
                    state,
                    reward_signal=reward_signal,
                )
                wall_avoidance.observe_transition(
                    prev_state,
                    prev_action,
                    state,
                    reward_signal=reward_signal,
                )
                capture_planner.observe_outcome(prev_state, prev_action, state, reward_signal=reward_signal)
                teacher_guard.observe_outcome(prev_key, prev_action, reward, prev_manual_override)
                prev_reward_value = reward
                memory.update(prev_key, prev_action, reward, key, allowed)
                step_since_save += 1

            stall_pressure = max(intro_stall_frames, stuck_count * 8)
            guide_action = guide_action_for_state(
                state,
                map_name,
                intro_action,
                phase,
                stuck_count,
                intro_stall_frames,
                desync_frames,
                last_action,
                action_history,
            )
            fallback_action = walkthrough_fallback_action(
                state,
                map_name,
                last_action,
                stuck_count,
                intro_stall_frames,
            ) if state["battle_mode"] == 0 else heuristic_action(state, intro_action, stuck_count, last_action)
            planner_packet = task_planner.plan(
                state,
                map_name,
                progress_snapshot,
                objective,
                guide_action=guide_action,
                fallback_action=fallback_action,
            )
            mission_packet = mission_scripts.script(
                state,
                map_name,
                progress_snapshot,
                guide_action=guide_action,
                fallback_action=fallback_action,
            )
            battle_packet = battle_brain.choose(state, progress_snapshot, planner_packet=planner_packet)
            capture_packet = capture_planner.plan(state, progress_snapshot)
            objective = planner_packet.objective
            if getattr(mission_packet, "objective_note", ""):
                objective = objective + " Mission: " + mission_packet.objective_note
            if getattr(battle_packet, "note", "") and state["battle_mode"] != 0:
                objective = objective + " Battle: " + battle_packet.note
            if getattr(capture_packet, "note", "") and state["battle_mode"] != 0:
                objective = objective + " Capture: " + capture_packet.note
            wall_scores = wall_avoidance.score_actions(
                state,
                allowed,
                guide_action=guide_action,
                fallback_action=fallback_action,
                last_action=last_action,
                stuck_count=stuck_count,
            )
            wall_summary = wall_avoidance.summary()
            recovery_action = recovery.recommend_action(
                state,
                allowed,
                guide_action=guide_action,
                fallback_action=fallback_action,
                last_action=last_action,
                blocked_action=wall_summary.get('blocked_action'),
                detour_action=wall_summary.get('detour_action'),
            )
            manual_override_action = detect_manual_override_action(
                state,
                MANUAL_ACTIONS,
                fallback=last_action,
            )
            manual_override_active = bool(manual_override_action)
            if manual_override_active:
                if manual_override_action == last_manual_demo_action:
                    manual_demo_hold += 1
                else:
                    last_manual_demo_action = manual_override_action
                    manual_demo_hold = 1
                if teacher_guard.consider(key, manual_override_action, manual_demo_hold):
                    memory.observe_teacher(key, manual_override_action)
            else:
                last_manual_demo_action = None
                manual_demo_hold = 0

            if manual_override_active:
                action = manual_override_action
            elif force_boot_action is not None:
                action = force_boot_action
                guide_action = force_boot_action
            else:
                action = pick_action(
                    state,
                    map_name,
                    objective,
                    memory,
                    smart_policy,
                    meta_policy,
                    wall_avoidance,
                    ollama,
                    intro_action,
                    phase,
                    stuck_count,
                    intro_stall_frames,
                    desync_frames,
                    last_action,
                    action_history,
                    repeated_action_streak=repeated_action_streak,
                    guide_action=guide_action,
                    progress_snapshot=progress_snapshot,
                    planner_packet=planner_packet,
                    recovery_action=recovery_action,
                    mission_packet=mission_packet,
                    battle_packet=battle_packet,
                    capture_packet=capture_packet,
                )
            keys = ACTIONS[action]
            packet = f"A|{keys}|2|{action}\n".encode("utf-8")
            try:
                sock.sendall(packet)
            except OSError:
                break

            trace_tick += 1
            if trace_tick % 10 == 0 or action != last_action:
                append_trace(
                    trace_path,
                    (
                        f"f={state['frame']} a={action} phase={phase} map={state['map_group']}-{state['map_number']}"
                        f" map_name={map_name}"
                        f" xy={state['x']},{state['y']} host={state['host_map_group']}-{state['host_map_number']}"
                        f" hxy={state['host_x']},{state['host_y']} ms={state['map_status']}"
                        f" menu={state['in_menu']} script={state['script_running']} jpd={state['joypad_disable']} party={state['party_count']}"
                        f" nm={state['naming_type']} mi={state['menu_items']}"
                        f" my={state['menu_y']} mx={state['menu_x']}"
                        f" box={state['menu_top']},{state['menu_left']},{state['menu_bottom']},{state['menu_right']}"
                        f" badges={state.get('badges_johto', 0) & 0xFF}/{state.get('badges_kanto', 0) & 0xFF}"
                        f" same={1 if same_map(state) else 0} desync={desync_frames} stuck={stuck_count}"
                        f" intro_stall={intro_stall_frames} stall_pressure={stall_pressure}"
                        f" mood={memory.reward_snapshot().get('mood', 'steady')} cookies={memory.reward_snapshot().get('cookies_total', 0.0):.2f} broccoli={memory.reward_snapshot().get('broccoli_total', 0.0):.2f}"
                        f" burn={memory.reward_snapshot().get('broccoli_burn_total', 0.0):.2f} repeat={repeated_action_streak}"
                        f" milestone={progress_snapshot.milestone_key} planner={progress_snapshot.active_planner}"
                        f" recovery={recovery_action or 'NONE'} pressure={recovery.recovery_pressure()} guide={guide_action} manual={manual_override_action or 'NONE'}"
                        f" ai_ttl={state.get('bridge_ai_ttl', 0)} ai_keys={state.get('bridge_ai_keys', 0)} raw={state.get('raw_keys', 0)} kr={state.get('keys_read_count', 0)}"
                    ),
                )

            dashboard.update({
                'frame': state['frame'],
                'map_name': map_name,
                'map_group': state['map_group'],
                'map_number': state['map_number'],
                'x': state['x'],
                'y': state['y'],
                'host_map_group': state['host_map_group'],
                'host_map_number': state['host_map_number'],
                'host_x': state['host_x'],
                'host_y': state['host_y'],
                'phase': phase,
                'objective': objective,
                'milestone': progress_snapshot.milestone_label,
                'planner': progress_snapshot.active_planner,
                'mission_label': getattr(mission_packet, 'label', ''),
                'battle_note': getattr(battle_packet, 'note', ''),
                'capture_note': getattr(capture_packet, 'note', ''),
                'cookies': memory.reward_snapshot().get('cookies_total', 0.0),
                'broccoli': memory.reward_snapshot().get('broccoli_total', 0.0),
                'mood': memory.reward_snapshot().get('mood', 'steady'),
                'recovery_action': recovery_action or 'NONE',
                'recovery_pressure': recovery.recovery_pressure(),
                'stuck_count': stuck_count,
                'repeat_streak': repeated_action_streak,
                'manual_override': manual_override_action or 'NONE',
                'teacher_summary': teacher_guard.summary(),
                'last_action': last_action,
                'guide_action': guide_action,
                'chosen_action': action,
                'wall_summary': wall_summary,
                'signal_summary': signal_snapshot.derived,
            })
            signal_map.export()
            teacher_guard.save()
            replay_logger.log_step({
                'frame': state['frame'],
                'map_name': map_name,
                'state_key': key,
                'action': action,
                'guide_action': guide_action,
                'manual_override_action': manual_override_action or 'NONE',
                'phase': phase,
                'objective': objective,
                'milestone_key': progress_snapshot.milestone_key,
                'planner': progress_snapshot.active_planner,
                'mission_key': getattr(mission_packet, 'key', ''),
                'battle_note': getattr(battle_packet, 'note', ''),
                'capture_note': getattr(capture_packet, 'note', ''),
                'reward_snapshot': memory.reward_snapshot(),
                'signal_summary': signal_snapshot.derived,
                'wall_summary': wall_summary,
                'recovery_pressure': recovery.recovery_pressure(),
                'prev_reward_value': prev_reward_value,
            })

            prev_state = state
            prev_key = key
            prev_action = action
            prev_guide_action = guide_action
            prev_stall_pressure = stall_pressure
            prev_manual_override = manual_override_active
            last_action = action
            action_history.append(action)

            if step_since_save >= 120:
                memory.save()
                step_since_save = 0

            # Hot-reload training data from disk every 5 real seconds so the
            # agent continuously picks up merged Q-tables written by the 10x runner.
            _now_t = time.time()
            if _now_t - last_hot_reload >= 5.0:
                memory.hot_reload_q()
                last_hot_reload = _now_t


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(0)
