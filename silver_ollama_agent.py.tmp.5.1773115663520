ACTIONS = {
    "NONE": 0,
    "UP": 1 << 6,
    "DOWN": 1 << 7,
    # mGBA key bit order: RIGHT=bit4, LEFT=bit5.
    "LEFT": 1 << 5,
    "RIGHT": 1 << 4,
    "A": 1 << 0,
    "B": 1 << 1,
    "UP_A": (1 << 6) | (1 << 0),
    "DOWN_A": (1 << 7) | (1 << 0),
    "LEFT_A": (1 << 5) | (1 << 0),
    "RIGHT_A": (1 << 4) | (1 << 0),
    "START": 1 << 3,
    "SELECT": 1 << 2,
}

OVERWORLD_ACTIONS = ["NONE", "UP", "DOWN", "LEFT", "RIGHT", "A", "UP_A", "DOWN_A", "LEFT_A", "RIGHT_A"]
BATTLE_ACTIONS = ["NONE", "A", "B", "UP", "DOWN", "LEFT", "RIGHT", "UP_A", "DOWN_A", "LEFT_A", "RIGHT_A"]
