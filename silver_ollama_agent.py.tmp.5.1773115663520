NUM_POKEMON = 251

# --- Goal priority tiers (evaluated top-to-bottom) ---
# The AI always pursues the highest-priority incomplete goal.

def _goal_status(state):
    """Return a dict summarising completion of every major goal."""
    johto = int(state.get("badges_johto", 0)) & 0xFF
    kanto = int(state.get("badges_kanto", 0)) & 0xFF
    return {
        "johto_badges": johto.bit_count(),
        "kanto_badges": kanto.bit_count(),
        "dex_caught": int(state.get("dex_caught", 0)),
        "dex_seen": int(state.get("dex_seen", 0)),
        "beat_elite_four": int(state.get("beat_elite_four", 0)),
        "beat_red": int(state.get("beat_red", 0)),
        "party_count": int(state.get("party_count", 0)),
        "party_detail": state.get("party_detail", []),
        "num_items": int(state.get("num_items", 0)),
        "num_key_items": int(state.get("num_key_items", 0)),
        "balls": int(state.get("balls", 0)),
    }


def story_objective(state, map_name):
    g = _goal_status(state)
    johto = g["johto_badges"]
    kanto = g["kanto_badges"]
    caught = g["dex_caught"]
    balls = g["balls"]

    # --- Tier 0: Intro / early game ---
    if johto == 0:
        if map_name in {"PLAYERS_HOUSE_2F", "PLAYERS_HOUSE_1F", "NEW_BARK_TOWN"}:
            return "Early game: leave home, finish mom intro, reach Elm's Lab, get starter."
        if map_name == "ELMS_LAB":
            return "Early game: claim starter, run first rival trigger, begin Route 29 progression."
        return (
            "Early game: push intro, lock in starter path, start Johto route. "
            "CATCH every new wild Pokemon you encounter, train your starter and team, "
            "and pick up all items on the ground. Use breeding later when it becomes available."
        )

    # --- Tier 1: Johto gym campaign + catch everything along the way ---
    if johto < 8:
        catch_note = ""
        if balls > 0:
            catch_note = (
                f" CATCH any wild Pokemon you haven't caught yet ({caught}/{NUM_POKEMON} owned), "
                "train your team for the next gym, breed for new species when possible, and pick up all items."
            )
        return (
            f"Johto campaign: defeat next Johto gym leader ({johto}/8 badges), "
            f"advance Team Rocket + lighthouse + radio story gates.{catch_note}"
        )

    # --- Tier 2: Elite Four ---
    if not g["beat_elite_four"]:
        return (
            f"League challenge: clear Victory Road and defeat the Elite Four + Champion Lance. "
            f"Grind if your team is below level 40. Catch and train new Pokemon on the way ({caught}/{NUM_POKEMON}), "
            f"and collect every item you can reach."
        )

    # --- Tier 3: Kanto gym circuit ---
    if kanto < 8:
        return (
            f"Kanto campaign: defeat next Kanto gym leader ({kanto}/8 badges). "
            f"Explore every route, catch every new species ({caught}/{NUM_POKEMON}), breed when useful, "
            f"train your team, and collect all items."
        )

    # --- Tier 4: Beat Red ---
    if not g["beat_red"]:
        return (
            f"Mt. Silver: climb to the summit and defeat Red. "
            f"Grind your team to level 70+. Catch remaining Pokemon ({caught}/{NUM_POKEMON}), "
            f"use breeding for remaining species, and keep collecting rare items. "
            f"Collect all TMs, Rare Candies, and key items."
        )

    # --- Tier 5: Completionist mop-up ---
    if caught < NUM_POKEMON:
        return (
            f"Completionist: catch remaining Pokemon ({caught}/{NUM_POKEMON}). "
            f"Fish, Surf, use Headbutt trees, breed, train evolving lines, and explore every cave. "
            f"Collect all remaining items."
        )

    return (
        f"ALL GOALS COMPLETE! {caught}/{NUM_POKEMON} Pokemon caught, "
        f"all 16 badges, Elite Four + Red defeated. "
        f"Continue exploring and collecting any missed items."
    )

def objective_route_pattern(state, map_name):
    """Broad walkthrough-derived movement bias when host sync is missing.

    This is intentionally not tile-perfect. It gives the agent a deterministic
    story-direction drift based on badge progress and current campaign phase,
    which is still far better than random wandering when it loses the host.
    """
    johto = int(state.get("badges_johto", 0)) & 0xFF
    kanto = int(state.get("badges_kanto", 0)) & 0xFF
    johto_count = johto.bit_count()
    kanto_count = kanto.bit_count()

    name = (map_name or "").upper()

    local_bias = [
        (("SPROUT_TOWER",), ["UP", "A", "UP", "RIGHT", "A"]),
        (("SLOWPOKE_WELL",), ["DOWN", "A", "LEFT", "A", "UP"]),
        (("ILEX_FOREST",), ["RIGHT", "UP", "A", "RIGHT", "UP"]),
        (("BURNED_TOWER",), ["UP", "A", "RIGHT", "UP", "A"]),
        (("LIGHTHOUSE",), ["UP", "A", "LEFT", "UP", "A"]),
        (("ROCKET_HIDEOUT", "RADIO_TOWER", "UNDERGROUND"), ["UP", "A", "RIGHT", "A", "LEFT"]),
        (("ICE_PATH",), ["UP", "RIGHT", "UP", "LEFT", "A"]),
        (("DRAGONS_DEN",), ["UP", "A", "RIGHT", "A", "UP"]),
        (("VICTORY_ROAD",), ["UP", "RIGHT", "A", "UP", "LEFT"]),
        (("ROCK_TUNNEL",), ["RIGHT", "UP", "A", "RIGHT", "UP"]),
        (("SEAFOAM",), ["LEFT", "UP", "A", "LEFT", "UP"]),
        (("MT_SILVER",), ["UP", "UP", "RIGHT", "A", "UP", "LEFT"]),
    ]
    for needles, pattern in local_bias:
        if any(n in name for n in needles):
            return pattern

    if johto_count == 0:
        return ["LEFT", "LEFT", "UP", "UP", "A", "LEFT", "UP"]
    if johto_count == 1:
        return ["DOWN", "DOWN", "LEFT", "LEFT", "A", "DOWN", "LEFT"]
    if johto_count == 2:
        return ["RIGHT", "RIGHT", "UP", "A", "RIGHT", "UP", "A"]
    if johto_count == 3:
        return ["UP", "RIGHT", "UP", "A", "LEFT", "UP", "A"]
    if johto_count in {4, 5}:
        return ["LEFT", "DOWN", "LEFT", "A", "UP", "LEFT", "A"]
    if johto_count == 6:
        return ["RIGHT", "UP", "RIGHT", "A", "UP", "RIGHT", "A"]
    if johto_count == 7:
        return ["RIGHT", "UP", "A", "UP", "LEFT", "UP", "A"]
    if johto_count >= 8 and not int(state.get("beat_elite_four", 0)):
        return ["DOWN", "RIGHT", "UP", "A", "RIGHT", "UP", "A"]
    if kanto_count == 0:
        return ["RIGHT", "UP", "A", "RIGHT", "UP", "A"]
    if kanto_count == 1:
        return ["UP", "RIGHT", "A", "UP", "LEFT", "UP", "A"]
    if kanto_count == 2:
        return ["RIGHT", "UP", "A", "LEFT", "UP", "A", "RIGHT"]
    if kanto_count == 3:
        return ["LEFT", "UP", "A", "LEFT", "DOWN", "LEFT", "A"]
    if kanto_count == 4:
        return ["LEFT", "DOWN", "A", "LEFT", "DOWN", "LEFT", "A"]
    if kanto_count == 5:
        return ["RIGHT", "RIGHT", "UP", "A", "RIGHT", "UP", "A"]
    if kanto_count == 6:
        return ["LEFT", "DOWN", "LEFT", "A", "LEFT", "UP", "A"]
    if kanto_count == 7 and not int(state.get("beat_red", 0)):
        return ["UP", "LEFT", "UP", "A", "UP", "RIGHT", "A"]
    return ["UP", "RIGHT", "A", "LEFT", "UP", "A"]



class Memory:
    def __init__(self, path: Path):
        self.path = path
        self.q = {}
        self.clone = {}
        self.steps = 0
        self.bad = []
        self.load()

    def load(self):
        if not self.path.exists():
            return
        try:
            data = json.loads(self.path.read_text(encoding="utf-8"))
            self.q = data.get("q", {})
            self.clone = data.get("clone", {})
            self.steps = int(data.get("steps", 0))
            self.bad = data.get("bad", [])[-30:]
        except Exception:
            pass

    def save(self):
        payload = {
            "q": self.q,
            "clone": self.clone,
            "steps": self.steps,
            "bad": self.bad[-30:],
        }
        self.path.write_text(json.dumps(payload, indent=2), encoding="utf-8")

    def qvalue(self, state_key, action):
        return float(self.q.get(state_key, {}).get(action, 0.0))

    def clonevalue(self, state_key, action):
        return float(self.clone.get(state_key, {}).get(action, 0.0))

    def best_action(self, state_key, allowed, fallback):
        row = self.q.get(state_key, {})
        best = fallback
        best_v = -10**9
        for action in allowed:
            v = float(row.get(action, 0.0))
            if v > best_v:
                best = action
                best_v = v
        return best

    def update(self, prev_state, prev_action, reward, next_state, allowed_next):
        alpha = 0.22
        gamma = 0.88
        row = self.q.setdefault(prev_state, {})
        old = float(row.get(prev_action, 0.0))
        next_best = 0.0
        if allowed_next:
            next_best = max(self.qvalue(next_state, a) for a in allowed_next)
        new_v = old + alpha * (reward + gamma * next_best - old)
        row[prev_action] = round(new_v, 6)
        self.steps += 1
        if reward <= -0.5:
            self.bad.append(
                {
                    "t": int(time.time()),
                    "state": prev_state,
                    "action": prev_action,
                    "reward": round(reward, 3),
                }
            )

    def observe_teacher(self, state_key, action):
        row = self.clone.setdefault(state_key, {})
        row[action] = round(float(row.get(action, 0.0)) + 1.0, 3)
        if len(row) > 10:
            keep = sorted(row.items(), key=lambda kv: kv[1], reverse=True)[:6]
            self.clone[state_key] = {k: v for k, v in keep}

    def best_clone_action(self, state_key, allowed, fallback):
        row = self.clone.get(state_key, {})
        if not row:
            return fallback
        best = fallback
        best_v = -10**9
        for action in allowed:
            v = float(row.get(action, 0.0))
            if v > best_v:
                best = action
                best_v = v
        return best


class Ollama:
