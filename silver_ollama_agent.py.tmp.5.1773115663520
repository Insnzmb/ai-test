            + ("Planner context: " + json.dumps(planner_context, separators=(",", ":")) + "\n" if planner_context else "")
            + "State: "
            + json.dumps(state, separators=(",", ":"))
            + "\nReturn only the action token."
        )
        payload = {
            "model": self.model,
            "prompt": prompt,
            "stream": False,
            "options": {"temperature": 0.15, "num_predict": 12},
        }
        req = urllib.request.Request(
            self.url,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
        )
        try:
            with urllib.request.urlopen(req, timeout=self.timeout) as resp:
                body = resp.read().decode("utf-8", errors="replace")
            data = json.loads(body)
            raw = (data.get("response") or "").strip().upper().replace(" ", "_")
            token = raw.splitlines()[0].split("`")[0].strip(" .,:;")
            if token in allowed:
                return token
            for action in allowed:
                if action in raw:
                    return action
            return None
        except Exception:
            self.cooldown_until = time.time() + 2.5
            return None


def _parse_party_detail(raw):
    """Parse 'sp:lv:hp:mhp,sp:lv:hp:mhp,...' into list of dicts."""
    if not raw or raw == "0":
        return []
    party = []
    for entry in raw.split(","):
        parts = entry.split(":")
        if len(parts) == 4:
            try:
                party.append({
                    "species": int(parts[0]),
                    "level": int(parts[1]),
                    "hp": int(parts[2]),
                    "max_hp": int(parts[3]),
                })
            except ValueError:
                pass
    return party


def parse_state(line):
    parts = line.strip().split("|")
    if parts[0] != "S":
        return None
    # First 37 fields (indices 1-37) are integers; field 42 (index 42) is party string.
    # Parse integers first, handle party string separately.
    raw = parts[1:]
    if len(raw) < 21:
        return None

    def intval(idx, fallback=0):
        if idx < len(raw):
            try:
                return int(raw[idx])
            except ValueError:
                return fallback
        return fallback

    def strval(idx, fallback=""):
        if idx < len(raw):
            return raw[idx]
        return fallback

    return {
        "frame": intval(0),
        "map_group": intval(1),
        "map_number": intval(2),
        "x": intval(3),
        "y": intval(4),
        "host_map_group": intval(5),
        "host_map_number": intval(6),
        "host_x": intval(7),
        "host_y": intval(8),
        "battle_mode": intval(9),
        "battle_type": intval(10),
        "in_menu": intval(11),
        "script_running": intval(12),
        "menu_y": intval(13),
        "menu_x": intval(14),
        "party_count": intval(15),
        "balls": intval(16),
        "enemy_hp": intval(17),
        "enemy_species": intval(18),
        "battle_menu_pos": intval(19),
        "joypad_disable": intval(20),
        "naming_type": intval(21),
        "menu_items": intval(22),
        "menu_top": intval(23),
        "menu_left": intval(24),
        "menu_bottom": intval(25),
        "menu_right": intval(26),
        "map_status": intval(27),
        "house_scene": intval(28),
        "script_bank": intval(29),
        "script_pos": intval(30),
        "badges_johto": intval(31),
        "badges_kanto": intval(32),
        "bridge_ai_ttl": intval(33),
        "bridge_ai_keys": intval(34),
        "raw_keys": intval(35),
        "keys_read_count": intval(36),
        # Extended telemetry
        "dex_caught": intval(37),
        "dex_seen": intval(38),
        "num_items": intval(39),
        "num_key_items": intval(40),
        "party_detail": _parse_party_detail(strval(41)),
        "beat_elite_four": intval(42),
        "beat_red": intval(43),
    }


def same_map(state):
    return (
        host_sync_available(state)
        and state["host_map_group"] == state["map_group"]
        and state["host_map_number"] == state["map_number"]
    )


def host_follow_ready(state):
    if not same_map(state):
        return False
    if state["host_x"] < 0 or state["host_y"] < 0:
        return False
    if state["battle_mode"] != 0:
        return False
    if state["in_menu"] != 0:
        return False
    if state["script_running"] != 0:
        return False
    if state["joypad_disable"] != 0:
        return False
    if state["map_status"] < 2:
        return False
    return True


def is_name_choice_menu(state):
    if state["menu_items"] != NAME_MENU_ITEMS:
        return False
    if state["map_group"] != 0 or state["map_number"] != 0 or state["map_status"] != 0:
        return False
    if state["naming_type"] not in (0, 1):
        return False
    # Cursor box can drift by a pixel/row depending on dialog transition timing;
    # accept a small window around the expected NEW NAME menu rectangle.
    if state["menu_top"] > (NAME_MENU_TOP + 2):
        return False
    if state["menu_left"] > (NAME_MENU_LEFT + 2):
        return False
    if state["menu_bottom"] < 9 or state["menu_bottom"] > (NAME_MENU_BOTTOM + 3):
        return False
    if state["menu_right"] < (NAME_MENU_RIGHT - 2) or state["menu_right"] > (NAME_MENU_RIGHT + 4):
        return False
    return True


def is_continue_menu_candidate(state):
    if state["battle_mode"] != 0:
        return False
    if state["map_group"] != 0 or state["map_number"] != 0:
        return False
    if state["map_status"] != 0:
        return False
    if state["script_running"] != 0:
        return False
    items = state["menu_items"]
    if items < CONTINUE_MENU_MIN_ITEMS or items > CONTINUE_MENU_MAX_ITEMS:
        return False
    if is_name_choice_menu(state):
        return False
    # Title/continue menu in GSC often reports in_menu=0 in this state.
    if state["menu_top"] > state["menu_bottom"] or state["menu_left"] > state["menu_right"]:
        return False
    if (state["menu_bottom"] - state["menu_top"]) < 2:
        return False
    if (state["menu_right"] - state["menu_left"]) < 4:
        return False
    # Some builds report in_menu=0 on the continue menu.
    # Accept both common box layouts: bottom-right and top-left anchored.
    if items <= 2 and state["in_menu"] == 0:
        plausible_box = (
            state["menu_bottom"] >= 4
            and state["menu_right"] >= 10
        )
        if not plausible_box:
            return False
    return True


def likely_naming_screen(state):
    if state["map_group"] != 0 or state["map_number"] != 0 or state["map_status"] != 0:
        return False
    if state["naming_type"] == 0:
        return False
    if is_name_choice_menu(state):
        return False
    if is_continue_menu_candidate(state):
        return False
    if (
        state["menu_top"] <= 2
        and state["menu_left"] <= 2
        and state["menu_bottom"] >= 8
        and state["menu_right"] >= 8
    ):
        return True
    if state["menu_items"] <= 1 and state["in_menu"] == 0:
        return True
    return False


def likely_boot_shell(state):
    if state["battle_mode"] != 0:
        return False
    if state["map_group"] != 0 or state["map_number"] != 0:
        return False
    if host_sync_available(state):
        return False
    if state["party_count"] > 1:
        return False
    if state["script_running"] not in (0, 1):
        return False
    if state["in_menu"] != 0:
        return True
    if state["map_status"] in (0, 255):
        return True
    return False


def on_home_intro_map(state):
    return state["map_group"] == 24 and state["map_number"] in (6, 7)


def opposite_move(action):
    table = {
        "UP": "DOWN",
        "DOWN": "UP",
        "LEFT": "RIGHT",
        "RIGHT": "LEFT",
        "UP_A": "DOWN_A",
        "DOWN_A": "UP_A",
        "LEFT_A": "RIGHT_A",
        "RIGHT_A": "LEFT_A",
    }
    return table.get(action, action)


def normalize_menu_pos(raw):
    # GSC menu cursors are sometimes 0..3, sometimes 1..4.
    if 0 <= raw <= 3:
        return raw
    if 1 <= raw <= 4:
        return raw - 1
    return -1


def nav_2x2(current, target):
    if current < 0:
        return "A"
    cur_row = 1 if current >= 2 else 0
    cur_col = 1 if (current % 2) == 1 else 0
    tgt_row = 1 if target >= 2 else 0
    tgt_col = 1 if (target % 2) == 1 else 0
    if cur_row < tgt_row:
        return "DOWN"
    if cur_row > tgt_row:
        return "UP"
    if cur_col < tgt_col:
        return "RIGHT"
    if cur_col > tgt_col:
        return "LEFT"
    return "A"


def movement_pair(dx, dy, last_action):
    horizontal = None
    vertical = None
    if dx > 0:
        horizontal = "RIGHT"
    elif dx < 0:
        horizontal = "LEFT"
    if dy > 0:
        vertical = "DOWN"
    elif dy < 0:
        vertical = "UP"

    if horizontal and not vertical:
        return horizontal, None
    if vertical and not horizontal:
        return vertical, None
    if not horizontal and not vertical:
        return "NONE", None

    if abs(dx) > abs(dy):
        return horizontal, vertical
    if abs(dy) > abs(dx):
        return vertical, horizontal

    if last_action in HORIZONTAL_ACTIONS:
        return horizontal, vertical
    if last_action in VERTICAL_ACTIONS:
        return vertical, horizontal
    return horizontal, vertical


def _is_species_caught(state, species_id):
    """Check if the enemy species is already in our party (rough proxy for caught).

    We can't read the full pokedex bitfield per-frame from the state line,
    but we CAN check if dex_caught went up on the next transition.
    For now, check if the species already appears in our party.
    """
    for mon in state.get("party_detail", []):
        if mon.get("species", 0) == species_id:
            return True
    return False


def battle_heuristic(state):
    if state["joypad_disable"] != 0:
        return "NONE"
    if state["script_running"] != 0:
        return "A"
    if state["in_menu"] == 0:
        return "A"

    menu_pos = normalize_menu_pos(state["battle_menu_pos"])
    enemy_hp = max(0, state["enemy_hp"])
    enemy_species = int(state.get("enemy_species", 0))
    balls = max(0, state["balls"])
    wild_battle = state["battle_type"] == 1

    # CATCHING PRIORITY: Try to catch any wild Pokemon, especially if
    # we don't already have its species in our party.
    # - Always try to catch at low HP (any species).
    # - At higher HP, weaken first then catch.
    already_have = _is_species_caught(state, enemy_species) if enemy_species > 0 else True
    want_catch = wild_battle and balls > 0 and enemy_hp > 0

    if want_catch:
        if enemy_hp <= 50 or (not already_have and enemy_hp <= 120):
            # HP low enough — go to PACK to throw a ball.
            return nav_2x2(menu_pos, 2)
        # HP still high — FIGHT to weaken it first.
        return nav_2x2(menu_pos, 0)

    # Trainer battle or no balls: bias to FIGHT (top-left).
    return nav_2x2(menu_pos, 0)


def follow_heuristic(state, stuck_count, last_action):
    if state["joypad_disable"] != 0:
        return "NONE"
    if state["script_running"] != 0:
        return "A"
    if state["in_menu"] != 0:
        return "A"
    if not same_map(state):
        return "NONE"

    dx = state["host_x"] - state["x"]
    dy = state["host_y"] - state["y"]
    dist = abs(dx) + abs(dy)
    if dist == 0:
        return "NONE"

    primary, secondary = movement_pair(dx, dy, last_action)
    if dist <= 1:
        if (state["frame"] % 20) == 0:
            return "A"
        return primary

    if stuck_count >= 10:
        pattern = []
        if secondary:
            pattern.append(secondary)
        pattern.extend([opposite_move(primary), "A", primary])
        idx = (state["frame"] // 6) % max(1, len(pattern))
        return pattern[idx]

    if dist >= 7:
        return primary
    if dist >= 3:
        if secondary and (state["frame"] % 13) == 0:
            return secondary
        return primary

    if (state["frame"] % 5) == 0:
        return "A"
    return primary


def walkthrough_fallback_action(state, map_name, last_action, stuck_count, intro_stall_frames):
    if state["joypad_disable"] != 0:
        return "NONE"
    if state["script_running"] != 0 or state["in_menu"] != 0:
        return "A"
    if map_name == "PLAYERS_HOUSE_2F" and state["house_scene"] == 0 and state["party_count"] == 0:
        # The wake-up script sometimes reports clear input before movement
        # truly unlocks. Tap A briefly, then force deterministic movement.
        if intro_stall_frames < 72:
            if pulse(state["frame"], 4, 2):
                return "A"
            return "NONE"
        if intro_stall_frames < 140 and pulse(state["frame"], 16, 1, 0):
            return "A"

    # Deterministic early-game route when host sync is missing:
    # bedroom stairs -> first floor exit -> Elm's Lab.
    target = None
    if map_name == "PLAYERS_HOUSE_2F":
        # Bedroom spawn can trap movement if we path directly to stairs.
        # Route through a clear interior tile first, then line up with stairs.
        if state["x"] <= 1 and state["y"] >= 3:
            target = (2, 2)
        elif state["x"] < 7 and state["y"] >= 2:
            target = (7, 2)
        else:
            target = (7, 1)
    elif map_name == "PLAYERS_HOUSE_1F":
        # Leaving stairs on 1F needs a short horizontal step before
        # moving downward into the mom-intro trigger lane.
        if stuck_count >= 80 and 7 <= state["x"] <= 9 and 3 <= state["y"] <= 4:
            # If we wedge near mom's trigger lane, explicitly face/talk first.
            mom_recover = ["UP", "A", "A", "DOWN", "LEFT", "DOWN"]
            return mom_recover[(state["frame"] // 4) % len(mom_recover)]
        if state["y"] <= 1:
            target = (8, 1)
        elif state["y"] < 4:
            target = (9, 4)
        else:
            target = (6, 7)
    else:
        route_targets = {
            "NEW_BARK_TOWN": (6, 3),
        }
        target = route_targets.get(map_name)

    if target is not None:
        tx, ty = target
        dx = tx - state["x"]
        dy = ty - state["y"]
        dist = abs(dx) + abs(dy)
        if map_name == "PLAYERS_HOUSE_2F" and intro_stall_frames >= 180 and stuck_count >= 8:
            recover2f = ["UP", "LEFT", "UP", "RIGHT", "UP", "A", "UP"]
            return recover2f[(state["frame"] // 4) % len(recover2f)]
        if stuck_count >= 10:
            recovery = ["DOWN", "RIGHT", "UP", "RIGHT", "LEFT", "DOWN", "RIGHT", "UP"]
            if map_name == "PLAYERS_HOUSE_1F":
                recovery = ["LEFT", "DOWN", "LEFT", "DOWN", "RIGHT", "DOWN", "LEFT"]
            return recovery[(state["frame"] // 4) % len(recovery)]
        if dist == 0:
            # Nudge into warp tile direction when standing exactly on it.
            warp_dir = "UP"
            if map_name in {"PLAYERS_HOUSE_2F", "PLAYERS_HOUSE_1F"}:
                warp_dir = "DOWN"
            if pulse(state["frame"], 6, 1):
                return warp_dir
            return "NONE"
        primary, secondary = movement_pair(dx, dy, last_action)
        if stuck_count >= 12 and secondary:
            if pulse(state["frame"], 4, 2):
                return secondary
        return primary

    # Deterministic walkthrough-derived exploration sequence for story progression
    # when host sync is unavailable. This biases the agent along the main game
    # route order instead of letting it wander randomly.
    pattern = objective_route_pattern(state, map_name)
    if stuck_count >= 12:
        pattern = list(pattern) + ["A"]
    action = pattern[(state["frame"] // 8) % max(1, len(pattern))]

    if (
        last_action in MOVEMENT_ACTIONS
        and action in MOVEMENT_ACTIONS
        and opposite_move(action) == last_action
    ):
        return last_action
    return action


def boot_recovery_action(state):
    # Safety net for title/start menus and blocked boot flow.
    frame = state["frame"]
    if state["battle_mode"] != 0:
        return None
    boot_map = is_boot_map(state)
    if not (likely_boot_shell(state) or boot_map):
        return None

    if state["in_menu"] != 0:
        items = state["menu_items"]
        if CONTINUE_MENU_MIN_ITEMS <= items <= CONTINUE_MENU_MAX_ITEMS:
            if pulse(frame, 8, 1, 0):
                return "UP"
            if pulse(frame, 8, 2, 2):
                return "A"
            return "NONE"
        if pulse(frame, 4, 2):
            return "A"
        return "NONE"
    if is_continue_menu_candidate(state):
        if pulse(frame, 12, 2, 0):
            return "START"
        if pulse(frame, 12, 2, 4):
            return "A"
        return "NONE"
    if boot_map:
        if pulse(frame, 8, 1, 0):
            return "START"
        if pulse(frame, 4, 2, 1):
            return "A"
        return "NONE"
    return None


class IntroDirector:
    def __init__(self, model_name: str, name_slot: int):
        if name_slot > 0:
            self.name_slot = clamp(name_slot, 1, 4)
        else:
            h = sum(ord(c) for c in model_name)
            self.name_slot = (h % 4) + 1
        self.queue = []
        self.name_selected = False
        self.agent_name = derive_agent_name(model_name)
        self.awaiting_name_entry = False
        self.await_name_deadline = -1
        self.name_entry_complete = False
        self.naming_homed = False
        self.boot_progress_latched = False
        self.last_phase = ""
        self.phase_started = -1

    def clear_name_flow(self):
        self.awaiting_name_entry = False
        self.await_name_deadline = -1
        self.name_entry_complete = False
        self.naming_homed = False
        self.queue = []

    def phase_age(self, phase, state):
        if phase != self.last_phase:
            self.last_phase = phase
            self.phase_started = state["frame"]
        if self.phase_started < 0:
            self.phase_started = state["frame"]
        return max(0, state["frame"] - self.phase_started)

    def phase(self, state):
        if state["map_group"] != 0 or state["map_number"] != 0 or state["map_status"] >= 2:
            self.boot_progress_latched = False
        if (
            state["map_group"] == 0
            and state["map_number"] == 0
            and state["map_status"] == 0
            and state["party_count"] == 0
            and (state["in_menu"] != 0 or state["script_running"] != 0 or state["naming_type"] != 0)
        ):
            self.boot_progress_latched = True
        if state["battle_mode"] != 0:
            return "BATTLE"
        if is_name_choice_menu(state):
            return "NAME_CHOICE"
        if likely_naming_screen(state) and (self.awaiting_name_entry or state["naming_type"] != 0):
            return "NAMING_SCREEN"
        if is_continue_menu_candidate(state):
            # Hidden continue telemetry can persist into Oak scenes; once intro
            # progression is latched, ignore in_menu=0 continue signatures.
            if self.boot_progress_latched and state["in_menu"] == 0:
                pass
            else:
                return "CONTINUE_MENU"
        if (
            self.boot_progress_latched
            and state["map_group"] == 0
            and state["map_number"] == 0
            and state["map_status"] == 0
        ):
            return "OAK_INTRO"
        if is_continue_menu_candidate(state):
            return "CONTINUE_MENU"
        if (
            state["map_group"] == 0
            and state["map_number"] == 0
            and state["map_status"] == 0
            and state["in_menu"] == 0
            and state["script_running"] == 0
        ):
            return "TITLE"
        if state["map_group"] == 0 and state["map_number"] == 0 and state["map_status"] == 0:
            return "OAK_INTRO"
        if on_home_intro_map(state) and state["party_count"] == 0 and state["house_scene"] == 0:
            return "MOM_INTRO"
        # Any loaded, non-boot map should be navigated as overworld.
        if state["map_group"] != 0 or state["map_number"] != 0:
            return "OVERWORLD"
        # When map is fully loaded and input is free, treat as overworld (follow can run),
        # even if intro flags are still zero.
        if (
            state["map_status"] >= 2
            and state["in_menu"] == 0
            and state["joypad_disable"] == 0
        ):
            return "OVERWORLD"
        return "OVERWORLD"

    def decide(self, state):
        if self.awaiting_name_entry and self.await_name_deadline > 0 and state["frame"] > self.await_name_deadline:
            self.clear_name_flow()
        if self.awaiting_name_entry and (
            state["map_group"] != 0 or state["map_number"] != 0 or state["map_status"] >= 2
        ):
            self.clear_name_flow()

        phase = self.phase(state)
        phase_age = self.phase_age(phase, state)
        if phase == "NAMING_SCREEN":
            if not self.name_entry_complete:
                if not self.naming_homed:
                    # Normalize cursor to top-left before typing so the fixed
                    # path for OLLAMA remains stable across menu variants.
                    if phase_age < 72:
                        if pulse(state["frame"], 6, 2, 0):
                            return "UP"
                        if pulse(state["frame"], 6, 2, 3):
                            return "LEFT"
                        return "NONE"
                    self.naming_homed = True
                if not self.queue:
                    self.queue = build_name_entry_queue(self.agent_name)
                if not self.queue:
                    self.name_entry_complete = True
                    return "NONE"
                if not pulse(state["frame"], 4, 1):
                    return "NONE"
                action = self.queue.pop(0)
                if not self.queue:
                    self.name_entry_complete = True
                return action
            # Keep trying END/confirm if a script box interrupted the first attempt.
            if pulse(state["frame"], 4, 1, 0):
                return "START"
            if pulse(state["frame"], 4, 1, 2):
                return "A"
            return "NONE"
        if phase == "TITLE":
            # Strong boot routine: some title states ignore A until START is pulsed.
            if pulse(state["frame"], 10, 2, 0):
                return "START"
            if pulse(state["frame"], 4, 2, 1):
                return "A"
            if phase_age > 240 and pulse(state["frame"], 20, 1, 8):
                return "DOWN"
            return "NONE"
        if phase == "CONTINUE_MENU":
            # Before a run is named, bias to NEW GAME so we can hit name entry.
            needs_new_game = (
                not self.name_entry_complete
                and not self.name_selected
                and state["party_count"] == 0
            )
            hidden_menu = state["in_menu"] == 0
            if needs_new_game:
                if hidden_menu:
                    if pulse(state["frame"], 12, 2, 0):
                        return "START"
                    if pulse(state["frame"], 12, 2, 4):
                        return "A"
                    if phase_age > 220 and pulse(state["frame"], 24, 1, 10):
                        return "DOWN"
                    if phase_age > 220 and pulse(state["frame"], 24, 1, 14):
                        return "A"
                    return "NONE"
                # First force cursor upward (NEW GAME), then confirm.
                if phase_age < 36:
                    if pulse(state["frame"], 6, 2):
                        return "UP"
                    return "NONE"
                # Prefer a deterministic UP+A rhythm. Some menu states ignore B.
                if pulse(state["frame"], 12, 2, 0):
                    return "UP"
                if pulse(state["frame"], 12, 2, 4):
                    return "A"
                # Long-stall fallback: briefly sweep DOWN then confirm once.
                if phase_age > 220 and pulse(state["frame"], 24, 1, 10):
                    return "DOWN"
                if phase_age > 220 and pulse(state["frame"], 24, 1, 14):
                    return "A"
                return "NONE"
            # Otherwise bias to the top entry (continue).
            if hidden_menu:
                if pulse(state["frame"], 12, 2, 0):
                    return "START"
                if pulse(state["frame"], 12, 2, 4):
                    return "A"
                return "NONE"
            if pulse(state["frame"], 8, 1, 0):
                return "UP"
            if pulse(state["frame"], 8, 2, 2):
                return "A"
            return "NONE"
        if phase == "NAME_CHOICE":
            if phase_age < 32:
                if pulse(state["frame"], 4, 2):
                    return "UP"
                return "NONE"
            # Telemetry cursor is often 1-based in this menu: treat 0/1 as top.
            if state["menu_y"] > 1:
                if pulse(state["frame"], 4, 2):
                    return "UP"
                return "NONE"
            # If selection does not open after repeated confirms, sweep one slot
            # down/up and retry to handle cursor indexing variants.
            if phase_age > 180:
                if pulse(state["frame"], 16, 1, 0):
                    return "DOWN"
                if pulse(state["frame"], 16, 1, 4):
                    return "A"
                if pulse(state["frame"], 16, 1, 8):
                    return "UP"
                if pulse(state["frame"], 16, 1, 12):
                    return "A"
                return "NONE"
            if phase_age < 120 and pulse(state["frame"], 6, 2, 0):
                return "UP"
            if pulse(state["frame"], 4, 2, 1):
                self.name_selected = True
                self.awaiting_name_entry = True
                self.await_name_deadline = state["frame"] + 1200
                self.name_entry_complete = False
                self.naming_homed = False
                self.queue = []
                return "A"
            return "NONE"
        if phase in ("OAK_INTRO", "MOM_INTRO"):
            if phase == "OAK_INTRO" and is_continue_menu_candidate(state):
                # Some title/continue screens are mis-labeled as OAK_INTRO when
                # boot progression has been latched. Always prioritize START/A
                # in that state so we do not drift into movement loops.
                if pulse(state["frame"], 12, 2, 0):
                    return "START"
                if pulse(state["frame"], 12, 2, 4):
                    return "A"
                return "NONE"
            if phase == "MOM_INTRO" and host_follow_ready(state):
                return None
            if (
                phase == "MOM_INTRO"
                and state["map_group"] == 24
                and state["map_number"] == 7
                and state["party_count"] == 0
                and state["script_running"] == 0
                and state["in_menu"] == 0
                and state["y"] <= 1
            ):
                if pulse(state["frame"], 6, 2):
                    return "DOWN"
                return "NONE"
            if state["in_menu"] != 0:
                if pulse(state["frame"], 3, 2):
                    return "A"
                return "NONE"
            if state["script_running"] != 0:
                if pulse(state["frame"], 3, 2):
                    return "A"
                return "NONE"
            if (
                phase == "MOM_INTRO"
                and state["map_group"] == 24
                and state["map_number"] in (6, 7)
                and state["party_count"] == 0
            ):
                # Let movement fallback route out of home once script/menu locks clear.
                return None
            if pulse(state["frame"], 6, 1):
                return "A"
            return "NONE"
        return None


def state_key(state):
    if state["battle_mode"] == 0:
        if (
            state["naming_type"] != 0
            and state["map_group"] == 0
            and state["map_number"] == 0
            and state["menu_bottom"] >= 14
        ):
            return f"NM:{state['menu_y']}:{state['menu_x']}:{state['script_running']}"
        if is_name_choice_menu(state):
            return f"NC:{state['menu_y']}:{state['menu_x']}:{state['script_running']}"
        if state["map_status"] == 0:
            return f"IN:{state['in_menu']}:{state['script_running']}:{state['menu_y']}:{state['menu_x']}"
        if same_map(state):
            dx = clamp(state["host_x"] - state["x"], -6, 6)
            dy = clamp(state["host_y"] - state["y"], -6, 6)
            return f"OW:1:{dx}:{dy}:{state['script_running']}:{state['in_menu']}:{state['house_scene']}"
        return f"OW:0:{state['script_running']}:{state['in_menu']}:{state['house_scene']}"
    hp_bucket = clamp(state["enemy_hp"] // 15, 0, 15)
    return (
        f"BT:{state['battle_mode']}:{state['battle_type']}:{state['in_menu']}:"
        f"{state['menu_y']}:{state['menu_x']}:{state['balls'] > 0}:{hp_bucket}"
    )


def allowed_actions(state, intro_action):
    if intro_action is not None:
        return INTRO_ACTIONS
    if state["battle_mode"] != 0:
        return BATTLE_ACTIONS
    return OVERWORLD_ACTIONS


def heuristic_action(state, intro_action, stuck_count, last_action):
    if intro_action is not None:
        return intro_action

    if state["battle_mode"] != 0:
        return battle_heuristic(state)

    return follow_heuristic(state, stuck_count, last_action)


def reward_for_transition(prev, curr, prev_action):
    reward = 0.0
    if prev["battle_mode"] == 0 and curr["battle_mode"] != 0:
        reward += 0.2
    if prev["battle_mode"] == 0 and curr["battle_mode"] == 0 and same_map(prev) and same_map(curr):
        prev_dist = abs(prev["host_x"] - prev["x"]) + abs(prev["host_y"] - prev["y"])
        curr_dist = abs(curr["host_x"] - curr["x"]) + abs(curr["host_y"] - curr["y"])
        if curr_dist < prev_dist:
            reward += 0.8
        elif curr_dist > prev_dist:
            reward -= 0.8
        if prev_action in MOVEMENT_ACTIONS and prev["x"] == curr["x"] and prev["y"] == curr["y"]:
            reward -= 0.35
    if curr["party_count"] > prev["party_count"]:
        reward += 5.0
    if prev["battle_mode"] != 0 and curr["battle_mode"] == 0 and curr["party_count"] == prev["party_count"]:
        reward += 0.4
    if curr["joypad_disable"] != 0:
        reward -= 0.1
    if prev["enemy_hp"] > curr["enemy_hp"] and curr["battle_mode"] != 0:
        reward += 0.3
    if curr["naming_type"] == 0 and prev["naming_type"] != 0:
        reward += 1.5
    if prev["map_status"] == 0 and curr["map_status"] != 0:
        reward += 1.2
    if prev["house_scene"] == 0 and curr["house_scene"] != 0:
        reward += 1.2
    return reward

def guide_action_for_state(
    state,
    map_name,
    intro_action,
    phase,
    stuck_count,
    intro_stall_frames,
    desync_frames,
    last_action,
    action_history,
):
    follow_priority = host_follow_ready(state)
    boot_action = boot_recovery_action(state)
    continue_like_boot = (
        state["map_group"] == 0
        and state["map_number"] == 0
        and state["map_status"] == 0
        and is_continue_menu_candidate(state)
    )
    if boot_action is not None and (intro_action is None or continue_like_boot):
        return boot_action

    planned_intro = intro_action
    if planned_intro is not None:
        if follow_priority:
            planned_intro = None
        stalled_intro = (
            phase in ("OAK_INTRO", "MOM_INTRO")
            and intro_stall_frames >= 180
            and state["script_running"] == 0
            and state["in_menu"] == 0
        )
        if planned_intro is not None and not stalled_intro:
            return planned_intro
        # Stalled OAK/MOM_INTRO: boot recovery must outrank random walkthrough so
        # the agent keeps pressing START/A on the continue screen instead of
        # wandering with movement keys when boot_progress_latched suppressed
        # CONTINUE_MENU phase detection.
        if stalled_intro and boot_action is not None:
            return boot_action

    if state["battle_mode"] == 0:
        follow_action = follow_heuristic(state, stuck_count, last_action)
        if same_map(state):
            return smooth_candidate(state, follow_action, last_action, action_history)
        if desync_frames < 36:
            return smooth_candidate(state, "NONE", last_action, action_history)
        fallback = walkthrough_fallback_action(
            state, map_name, last_action, stuck_count, intro_stall_frames
        )
        return smooth_candidate(state, fallback, last_action, action_history)

    return battle_heuristic(state)



def teacher_action(prev, curr):
    if prev["battle_mode"] != 0 or curr["battle_mode"] != 0:
        return None
    if prev["host_map_group"] < 0:
        return None
    if prev["host_map_group"] != curr["host_map_group"] or prev["host_map_number"] != curr["host_map_number"]:
        return None
    dx = curr["host_x"] - prev["host_x"]
    dy = curr["host_y"] - prev["host_y"]
    if dx == 0 and dy == 0:
        return None
    if abs(dx) >= abs(dy):
        return "RIGHT" if dx > 0 else "LEFT"
    return "DOWN" if dy > 0 else "UP"


def smooth_candidate(state, candidate, last_action, action_history):
    if candidate not in MOVEMENT_ACTIONS:
        return candidate

    if last_action in MOVEMENT_ACTIONS and opposite_move(candidate) == last_action:
        if len(action_history) >= 3:
            tail = list(action_history)[-3:]
            if all(a in MOVEMENT_ACTIONS for a in tail):
                # Avoid visible jitter between opposite directions — but only if the
                # recent history shows variety (true jitter).  If all recent actions
                # are the *same* direction we are stuck against a wall; forcing
                # last_action again would keep hammering the same wall indefinitely,
                # preventing recovery from breaking through.
                if len(set(tail)) > 1:
                    return last_action

    if same_map(state):
        dx = state["host_x"] - state["x"]
        dy = state["host_y"] - state["y"]
        dist = abs(dx) + abs(dy)
        if dist >= 4 and last_action in MOVEMENT_ACTIONS and candidate != last_action:
            if (state["frame"] % 2) == 0:
                # Don't repeat a stuck action.  If the last 3 actions are all the
                # same direction the AI is probably bumping a wall — let the new
                # candidate through so recovery/wall-avoidance can steer around it.
                tail = list(action_history)[-3:] if len(action_history) >= 3 else list(action_history)
                if len(tail) < 3 or len(set(tail)) > 1:
                    return last_action
    return candidate


def pick_action(
    state,
    map_name,
    objective,
    memory,
    smart_policy,
    meta_policy,
    wall_avoidance,
    ollama,
    intro_action,
    phase,
    stuck_count,
    intro_stall_frames,
    desync_frames,
    last_action,
    action_history,
    repeated_action_streak=0,
    guide_action=None,
    progress_snapshot=None,
    planner_packet=None,
    recovery_action=None,
    mission_packet=None,
    battle_packet=None,
    capture_packet=None,
):
    follow_priority = host_follow_ready(state)
    boot_action = boot_recovery_action(state)
    continue_like_boot = (
        state["map_group"] == 0
        and state["map_number"] == 0
        and state["map_status"] == 0
        and is_continue_menu_candidate(state)
    )
    if boot_action is not None and (intro_action is None or continue_like_boot):
        return boot_action

    if intro_action is not None:
        if follow_priority:
            intro_action = None
        stalled_intro = (
            phase in ("OAK_INTRO", "MOM_INTRO")
            and intro_stall_frames >= 180
            and state["script_running"] == 0
            and state["in_menu"] == 0
        )
        if intro_action is not None and not stalled_intro:
            return intro_action
        # Stalled OAK/MOM_INTRO: boot recovery must outrank random walkthrough so
        # the agent keeps pressing START/A on the continue screen instead of
        # wandering with movement keys when boot_progress_latched suppressed
        # CONTINUE_MENU phase detection.
        if stalled_intro and boot_action is not None:
            return boot_action

    if state["battle_mode"] == 0:
        follow_action = follow_heuristic(state, stuck_count, last_action)
        if same_map(state):
            return smooth_candidate(state, follow_action, last_action, action_history)

        # If host sync is temporarily missing, avoid random interactions.
        if desync_frames < 36:
            if recovery_action in OVERWORLD_ACTIONS:
                return smooth_candidate(state, recovery_action, last_action, action_history)
            idle = "NONE"
            return smooth_candidate(state, idle, last_action, action_history)

        # If host sync stays missing, keep playing via walkthrough fallback.
        fallback = walkthrough_fallback_action(
            state, map_name, last_action, stuck_count, intro_stall_frames
        )
        key = state_key(state)
        allowed = OVERWORLD_ACTIONS
        q_best = memory.best_action(key, allowed, fallback)
        clone_best = memory.best_clone_action(key, allowed, fallback)

        ollama_pick = None
        if ollama and ((desync_frames % 90) == 0 or stuck_count >= 6 or intro_stall_frames >= 48):
            ollama_pick = ollama.choose(
                state,
                allowed,
                fallback,
                q_best,
                clone_best,
                phase,
                objective,
                map_name,
                memory.bad,
                memory.reward_snapshot(),
                progress_context=(progress_snapshot.to_prompt_dict() if progress_snapshot is not None else {}),
                planner_context=(planner_packet.to_prompt_dict() if planner_packet is not None else {}),
            )
        reward_state = memory.reward_snapshot()
        broccoli_dislike = float(reward_state.get('broccoli_dislike', 1.35) or 1.35)

        scores = {}
        for action in allowed:
            q = memory.qvalue(key, action)
            c = memory.clonevalue(key, action)
            scores[action] = (q * 0.48) + (math.log1p(c) * 1.05)

        smart_scores = smart_policy.score_actions(
            state,
            allowed,
            memory_clone=memory.clone,
            guide_action=guide_action,
            heuristic=fallback,
            fallback=fallback,
            q_best=q_best,
            clone_best=clone_best,
            ollama_pick=ollama_pick,
            last_action=last_action,
            action_history=action_history,
            stuck_count=stuck_count,
            repeated_action_streak=repeated_action_streak,
            intro_stall_frames=intro_stall_frames,
            desync_frames=desync_frames,
        )
        for action, value in smart_scores.items():
            scores[action] = scores.get(action, 0.0) + float(value)

        meta_scores = meta_policy.score_actions(
            state,
            allowed,
            reward_state=reward_state,
            objective=objective,
            map_name=map_name,
            guide_action=guide_action,
            fallback=fallback,
            last_action=last_action,
            repeated_action_streak=repeated_action_streak,
            stuck_count=stuck_count,
            desync_frames=desync_frames,
        )
        for action, value in meta_scores.items():
            scores[action] = scores.get(action, 0.0) + float(value)

        wall_scores = wall_avoidance.score_actions(
            state,
            allowed,
            guide_action=guide_action,
            fallback_action=fallback,
            last_action=last_action,
            stuck_count=stuck_count,
        )
        for action, value in wall_scores.items():
            scores[action] = scores.get(action, 0.0) + float(value)

        if planner_packet is not None:
            for action, value in dict(getattr(planner_packet, "scores", {}) or {}).items():
                if action in allowed:
                    scores[action] = scores.get(action, 0.0) + float(value)
        if recovery_action in allowed:
            scores[recovery_action] = scores.get(recovery_action, 0.0) + (2.6 if stuck_count >= 4 else 1.3)
        if mission_packet is not None:
            for action, value in dict(getattr(mission_packet, "scores", {}) or {}).items():
                if action in allowed:
                    scores[action] = scores.get(action, 0.0) + float(value) * CONFIG.mission_script_bonus

        scores[fallback] = scores.get(fallback, 0.0) + 3.2
        if guide_action in allowed:
            scores[guide_action] = scores.get(guide_action, 0.0) + 2.8
        scores[q_best] = scores.get(q_best, 0.0) + 0.9
        scores[clone_best] = scores.get(clone_best, 0.0) + 1.8
        if ollama_pick in allowed:
            scores[ollama_pick] = scores.get(ollama_pick, 0.0) + 0.55

        if "NONE" in scores:
            none_penalty = 0.0
            if guide_action and guide_action != "NONE":
                none_penalty += 1.05 * broccoli_dislike
            if stuck_count >= 4 or intro_stall_frames >= 40:
                none_penalty += 0.85 * broccoli_dislike
            if none_penalty > 0.0:
                scores["NONE"] = scores.get("NONE", 0.0) - none_penalty

        candidate = max(scores.items(), key=lambda kv: kv[1])[0]
        return smooth_candidate(state, candidate, last_action, action_history)

    key = state_key(state)
    allowed = allowed_actions(state, intro_action)
    heuristic = heuristic_action(state, intro_action, stuck_count, last_action)
    q_best = memory.best_action(key, allowed, heuristic)
    clone_best = memory.best_clone_action(key, allowed, heuristic)

    ollama_pick = None
    if ollama:
        consult = False
        if state["battle_mode"] != 0:
            consult = True
        elif stuck_count >= 10:
            consult = True
        if consult:
            ollama_pick = ollama.choose(
                state,
                allowed,
                heuristic,
                q_best,
                clone_best,
                phase,
                objective,
                map_name,
                memory.bad,
                memory.reward_snapshot(),
                progress_context=(progress_snapshot.to_prompt_dict() if progress_snapshot is not None else {}),
                planner_context=(planner_packet.to_prompt_dict() if planner_packet is not None else {}),
            )

    reward_state = memory.reward_snapshot()
    broccoli_dislike = float(reward_state.get('broccoli_dislike', 1.35) or 1.35)

    scores = {}
    for action in allowed:
        q = memory.qvalue(key, action)
        c = memory.clonevalue(key, action)
        scores[action] = (q * 0.55) + (math.log1p(c) * 0.95)

    smart_scores = smart_policy.score_actions(
        state,
        allowed,
        memory_clone=memory.clone,
        guide_action=guide_action,
        heuristic=heuristic,
        fallback=heuristic,
        q_best=q_best,
        clone_best=clone_best,
        ollama_pick=ollama_pick,
        last_action=last_action,
        action_history=action_history,
        stuck_count=stuck_count,
        repeated_action_streak=repeated_action_streak,
        intro_stall_frames=intro_stall_frames,
        desync_frames=desync_frames,
    )
    for action, value in smart_scores.items():
        scores[action] = scores.get(action, 0.0) + float(value)

    meta_scores = meta_policy.score_actions(
        state,
        allowed,
        reward_state=reward_state,
        objective=objective,
        map_name=map_name,
        guide_action=guide_action,
        fallback=heuristic,
        last_action=last_action,
        repeated_action_streak=repeated_action_streak,
        stuck_count=stuck_count,
        desync_frames=desync_frames,
    )
    for action, value in meta_scores.items():
        scores[action] = scores.get(action, 0.0) + float(value)

    if planner_packet is not None:
        for action, value in dict(getattr(planner_packet, "scores", {}) or {}).items():
            if action in allowed:
                scores[action] = scores.get(action, 0.0) + float(value)
    if recovery_action in allowed:
        scores[recovery_action] = scores.get(recovery_action, 0.0) + (2.2 if stuck_count >= 4 or intro_stall_frames >= 24 else 0.9)
    if mission_packet is not None:
        for action, value in dict(getattr(mission_packet, "scores", {}) or {}).items():
            if action in allowed:
                scores[action] = scores.get(action, 0.0) + float(value) * CONFIG.mission_script_bonus
    if battle_packet is not None:
        for action, value in dict(getattr(battle_packet, "scores", {}) or {}).items():
            if action in allowed:
                scores[action] = scores.get(action, 0.0) + float(value) * CONFIG.battle_brain_bonus
    if capture_packet is not None:
        for action, value in dict(getattr(capture_packet, "scores", {}) or {}).items():
            if action in allowed:
                scores[action] = scores.get(action, 0.0) + float(value) * CONFIG.capture_bonus

    scores[heuristic] = scores.get(heuristic, 0.0) + 2.2
    if guide_action in allowed:
        scores[guide_action] = scores.get(guide_action, 0.0) + 2.4
    scores[q_best] = scores.get(q_best, 0.0) + 0.75
    scores[clone_best] = scores.get(clone_best, 0.0) + 1.2
    if ollama_pick:
        scores[ollama_pick] = scores.get(ollama_pick, 0.0) + (0.8 if state["battle_mode"] != 0 else 0.35)

    if "NONE" in scores:
        none_penalty = 0.0
        if state["battle_mode"] != 0:
            none_penalty += 1.2 * broccoli_dislike
        if guide_action and guide_action != "NONE":
            none_penalty += 1.15 * broccoli_dislike
        if stuck_count >= 6 or intro_stall_frames >= 60:
            none_penalty += 1.1 * broccoli_dislike
        if none_penalty > 0.0:
            scores["NONE"] = scores.get("NONE", 0.0) - none_penalty

    explore = 0.012 if memory.steps < 2400 else 0.004
    if state["battle_mode"] != 0:
        explore *= 0.6
    elif same_map(state):
        dist = abs(state["host_x"] - state["x"]) + abs(state["host_y"] - state["y"])
        if dist >= 3:
            explore = min(explore, 0.0025)

    if random.random() < explore:
        candidate = random.choice(allowed)
    else:
        candidate = max(scores.items(), key=lambda kv: kv[1])[0]
    return smooth_candidate(state, candidate, last_action, action_history)


def connect_loop(host, port):
    while True:
        try:
            sock = socket.create_connection((host, port), timeout=2.0)
            sock.settimeout(2.0)
            return sock
        except OSError:
            time.sleep(1.0)


def load_text(path: Path, limit: int):
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return ""
    raw = " ".join(raw.split())
    if len(raw) > limit:
        raw = raw[:limit]
    return raw


def append_trace(path: Path | None, line: str):
    if path is None:
        return
    try:
        with path.open("a", encoding="utf-8") as f:
            f.write(line + "\n")
    except OSError:
        pass


